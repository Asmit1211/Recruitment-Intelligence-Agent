        <uipath:inputOutput id="skills" name="skills" type="jsonSchema" subType="string" elementId="Activity_bJD7Sw"><![CDATA[{"type":"array","description":"All explicitly listed skills from the resume as concise strings.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="technicalSkills" name="technical_skills" type="jsonSchema" subType="string" elementId="Activity_bJD7Sw"><![CDATA[{"type":"array","description":"Programming languages, frameworks, libraries, databases, cloud platforms, DevOps tools, AI/ML frameworks, version control, IDEs, APIs, and software tools explicitly present in the resume.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
